# ===== Configuração do serviço — copie para .env e preencha =====
# (nada aqui é fixo do nosso ambiente; tudo é definido por quem instala)

# --- LLM (geração de texto) ---
# Emitida pela Anthropic em console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Banco de dados (escolha UM; vazio = SQLite local p/ desenvolvimento) ---
# PostgreSQL:     postgresql://usuario:senha@host:5432/curadoria
# MySQL/MariaDB:  mysql://usuario:senha@host:3306/curadoria
DATABASE_URL=

# --- Embeddings do RAG (escolha o provedor) ---
EMBED_PROVIDER=vertex            # vertex | bedrock | openai
# Vertex (GCP): usa credencial GCP do ambiente (service account / ADC)
#VERTEX_PROJECT=seu-projeto-gcp
#VERTEX_REGION=us-central1
# Bedrock (AWS): além de EMBED_PROVIDER=bedrock, definir:
#AWS_REGION=us-east-1
#EMBED_DIM=1024                  # Titan v2
# OpenAI:
#OPENAI_API_KEY=sk-...

# --- Acesso ---
BASIC_AUTH_USER=admin                       # usuário do login da curadoria
BASIC_AUTH_PASS=troque-esta-senha           # senha que VOCÊ escolhe
CONTENT_API_KEY=gere-uma-string-aleatoria   # string que VOCÊ gera: openssl rand -hex 32
